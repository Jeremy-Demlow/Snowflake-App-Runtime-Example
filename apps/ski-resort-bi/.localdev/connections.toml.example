# Copy to .localdev/connections.toml (gitignored) and fill in real values.
# Absolute private_key_file path. Used for local `streamlit run` only;
# in SPCS the entrypoint generates connections.toml from the mounted secret.

[myconnection]
account = "YOUR_ACCOUNT"            # e.g. trb65519
user = "YOUR_USER"                  # e.g. JDEMLOW
authenticator = "SNOWFLAKE_JWT"
private_key_file = "/absolute/path/to/rsa_key.p8"
role = "SKI_READONLY"
warehouse = "SKI_DEMO_WH"
database = "SKI_RESORT_DEMO"
schema = "MARTS"

[ski_readonly]
account = "YOUR_ACCOUNT"
user = "YOUR_USER"
authenticator = "SNOWFLAKE_JWT"
private_key_file = "/absolute/path/to/rsa_key.p8"
role = "SKI_READONLY"
warehouse = "SKI_DEMO_WH"
database = "SKI_RESORT_DEMO"
schema = "MARTS"
